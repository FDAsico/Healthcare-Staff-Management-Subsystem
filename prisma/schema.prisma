generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  user_id       String   @id @default(uuid())
  username      String   @unique
  email         String   @unique
  passwordHash  String
  role          String
  isActive      Boolean  @default(true)
  lastLogin     DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  staffProfile Staff?
  refreshTokens RefreshToken[]
}

model RefreshToken {
  token_id   String   @id @default(uuid())
  user_id    String
  user       User     @relation(fields: [user_id], references: [user_id], onDelete: Cascade)
  token      String   @unique
  expiresAt  DateTime
  createdAt  DateTime @default(now())

  @@index([user_id])
}

model Department {
  department_id String   @id @default(uuid())
  name          String   @unique
  description   String?
  location      String?
  contactEmail  String?
  contactPhone  String?
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  staff     Staff[]
  schedules Schedule[]
}

model Staff {
  staff_id       String   @id @default(uuid())
  user_id        String   @unique
  user           User     @relation(fields: [user_id], references: [user_id], onDelete: Cascade)

  employeeId     String   @unique
  firstName      String
  lastName       String
  middleName     String?
  dateOfBirth    DateTime?
  gender         Gender?
  email          String?
  phone          String?
  address        String?

  role           StaffRole
  department_id  String?
  department     Department? @relation(fields: [department_id], references: [department_id])
  status         StaffStatus @default(ACTIVE)

  hiredAt        DateTime    @default(now())
  terminatedAt   DateTime?
  updatedAt      DateTime    @updatedAt

  schedules      Schedule[]
  attendances    Attendance[]
  availability   Availability?
  leaveRequests  LeaveRequest[]
  documents      StaffDocument[]
  emergencyContacts EmergencyContact[]

  @@index([department_id])
  @@index([status])
  @@index([role])
}

enum Gender {
  MALE
  FEMALE
  OTHER
  PREFER_NOT_TO_SAY
}

enum StaffRole {
  DOCTOR
  NURSE
  PHARMACIST
  ADMIN
}

enum StaffStatus {
  ACTIVE
  ON_LEAVE
  SUSPENDED
  RESIGNED
  TERMINATED
}

model Schedule {
  schedule_id   String         @id @default(uuid())
  staff_id      String
  staff         Staff          @relation(fields: [staff_id], references: [staff_id], onDelete: Cascade)

  department_id String?
  department    Department?    @relation(fields: [department_id], references: [department_id])

  shiftDate     DateTime
  startTime     DateTime
  endTime       DateTime
  shiftType     ShiftType      @default(REGULAR)
  status        ScheduleStatus @default(SCHEDULED)
  notes         String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  attendances   Attendance[]

  @@index([staff_id])
  @@index([shiftDate])
}

enum ShiftType {
  REGULAR
  OVERTIME
  ON_CALL
  HOLIDAY
  NIGHT_SHIFT
  WEEKEND
}

enum ScheduleStatus {
  SCHEDULED
  CONFIRMED
  CANCELLED
  COMPLETED
  NO_SHOW
}

model Attendance {
  attendance_id String           @id @default(uuid())
  staff_id      String
  staff         Staff            @relation(fields: [staff_id], references: [staff_id], onDelete: Cascade)
  schedule_id   String?
  schedule      Schedule?        @relation(fields: [schedule_id], references: [schedule_id], onDelete: SetNull)

  date          DateTime
  timeIn        DateTime?
  timeOut       DateTime?
  status        AttendanceStatus
  remarks       String?
  createdAt     DateTime         @default(now())

  @@index([staff_id])
  @@index([date])
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  HALF_DAY
  ON_LEAVE
  EARLY_DEPARTURE
}

model Availability {
  availability_id String   @id @default(uuid())
  staff_id        String   @unique
  staff           Staff    @relation(fields: [staff_id], references: [staff_id], onDelete: Cascade)

  isAvailable     Boolean  @default(true)
  reason          String?
  availableFrom   DateTime?
  availableUntil  DateTime?
  updatedAt       DateTime @updatedAt
}

model LeaveRequest {
  leave_id    String        @id @default(uuid())
  staff_id    String
  staff       Staff         @relation(fields: [staff_id], references: [staff_id], onDelete: Cascade)

  leaveType   LeaveType
  startDate   DateTime
  endDate     DateTime
  totalDays   Float
  reason      String?
  status      LeaveStatus   @default(PENDING)
  reviewedBy  String?
  reviewedAt  DateTime?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt

  @@index([staff_id])
  @@index([status])
}

enum LeaveType {
  SICK
  VACATION
  EMERGENCY
  MATERNITY
  PATERNITY
  UNPAID
  BEREAVEMENT
  STUDY
  MEDICAL
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

model StaffDocument {
  document_id   String       @id @default(uuid())
  staff_id      String
  staff         Staff        @relation(fields: [staff_id], references: [staff_id], onDelete: Cascade)

  documentType  DocumentType
  title         String
  fileUrl       String?
  issuedBy      String?
  issueDate     DateTime?
  expiryDate    DateTime?
  isVerified    Boolean      @default(false)
  verifiedBy    String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
}

enum DocumentType {
  MEDICAL_LICENSE
  BOARD_CERTIFICATION
  DEGREE
  TRAINING_CERTIFICATE
  BACKGROUND_CHECK
  ID_PROOF
  CONTRACT
  INSURANCE
  VACCINATION_RECORD
}

model EmergencyContact {
  contact_id    String   @id @default(uuid())
  staff_id      String
  staff         Staff    @relation(fields: [staff_id], references: [staff_id], onDelete: Cascade)

  name          String
  relationship  String
  phone         String
  email         String?
  address       String?
  isPrimary     Boolean  @default(false)
}

model AuditLog {
  log_id        String   @id @default(uuid())
  performedBy   String?
  action        String
  entity        String
  entityId      String?
  oldValue      Json?
  newValue      Json?
  ipAddress     String?
  performedAt   DateTime @default(now())
}